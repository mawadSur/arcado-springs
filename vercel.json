{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "_comment_project": "Arcado Springs landing page. Plain static files served from /public (index.html, styles.css, main.js, /screenshots, /unity-build). No framework, no build step.",
  "_comment_brotli": "The shipping Unity WebGL build uses WebGLCompressionFormat.Brotli WITH decompressionFallback = TRUE. Every asset is named after the build folder (WebGL.*) and carries the .unityweb extension. Unity's OWN loader.js fetches the .unityweb files and decompresses them in JavaScript. We therefore serve the .unityweb files as PLAIN STATIC BYTES (Content-Type: application/octet-stream) and MUST NOT set any Content-Encoding (br/gzip) header on them — doing so would make the browser pre-decompress, then Unity would double-decompress, producing garbage and a broken player. WebGL.loader.js stays application/javascript. We only set the real Content-Type and a long immutable Cache-Control on /unity-build/Build/*.",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/unity-build/Build/(.*)\\.unityweb",
      "headers": [
        { "key": "Content-Type", "value": "application/octet-stream" },
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/unity-build/Build/(.*)\\.loader\\.js",
      "headers": [
        { "key": "Content-Type", "value": "application/javascript" },
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/unity-build/Build/(.*)\\.wasm",
      "headers": [
        { "key": "Content-Type", "value": "application/wasm" },
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/unity-build/Build/(.*)\\.framework\\.js",
      "headers": [
        { "key": "Content-Type", "value": "application/javascript" },
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/unity-build/Build/(.*)\\.data",
      "headers": [
        { "key": "Content-Type", "value": "application/octet-stream" },
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/unity-build/Build/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/unity-build/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.symbols\\.json",
      "headers": [
        { "key": "Content-Type", "value": "application/octet-stream" }
      ]
    },
    {
      "source": "/screenshots/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, must-revalidate" }
      ]
    },
    {
      "source": "/((?!unity-build/).*)\\.(css|js)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
